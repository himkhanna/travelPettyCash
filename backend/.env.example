# Backend environment overrides. Copy to backend/.env and fill in
# real values. backend/.env is gitignored.
#
# scripts/dev-up.ps1 sources this file before launching gradle so
# the values land in the JVM as system properties.

# ---- Smart Dubai OIDC (ADR-001) ----
# Get these from the Dubai-Gov IdP team. The first is public-ish
# (referenced in URLs), the second is a secret — never paste it
# anywhere you wouldn't paste a database password.
PDD_SMARTDUBAI_ENABLED=false
PDD_SMARTDUBAI_CLIENT_ID=
PDD_SMARTDUBAI_CLIENT_SECRET=

# ---- UAE Pass OIDC (ADR-002) ----
# Off by default. Defaults target the public staging sandbox
# (client_id=client_secret=sandbox_stage), so you only need to flip
# ENABLED to true to try the sandbox flow. For real staging/prod, set
# the CLIENT_ID/SECRET issued by TDRA.
PDD_UAEPASS_ENABLED=false
PDD_UAEPASS_CLIENT_ID=sandbox_stage
PDD_UAEPASS_CLIENT_SECRET=sandbox_stage

# ---- Database (override the dev defaults if needed) ----
# PDD_DB_URL=jdbc:postgresql://localhost:5432/pdd_petty_cash
# PDD_DB_USER=pdd
# PDD_DB_PASSWORD=pdd
